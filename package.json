{
  "name": "astro-suite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-app shell hosting interactive astronomy diagrams (H-R, Hubble, …) with a shared Aladin sky viewer and tabbed UI.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:embed": "tsc --noEmit && vite build --config vite.embed.config.ts",
    "build:data": "tsx scripts/build-data.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:responsive": "playwright test",
    "deploy": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "katex": "^0.16.45"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/d3": "^7.4.3",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.5.0",
    "firebase-tools": "^15.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.4"
  }
}
